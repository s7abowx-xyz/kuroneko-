# --- App ---
APP_URL="http://localhost:3000"
NODE_ENV="development"

# --- Database (Postgres — Neon, Supabase, Vercel Postgres, etc.) ---
DATABASE_URL="postgresql://user:password@host:5432/kuroneko?schema=public"

# --- Session signing (generate with: openssl rand -base64 33) ---
AUTH_SECRET="change-me"

# --- Bot / security check (Cloudflare-style verification page at /verify) ---
ENABLE_BOT_CHECK="true"

# --- Cloudflare Turnstile (the widget embedded inside the login/register forms) ---
# Create a site at: https://dash.cloudflare.com/?to=/:account/turnstile
# Leave empty to fall back to Cloudflare's public test key (always passes — dev only).
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# --- AI providers (only set the ones you want to enable) ---
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-5"

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"
