{
  "name": "kuroneko",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "build": "prisma generate && tsc && npm run copy-assets",
    "copy-assets": "mkdir -p dist/src dist/router && cp -r src/*.json src/*.jpg dist/src/ 2>/dev/null || true && cp -r public dist/ 2>/dev/null || true",
    "postinstall": "prisma generate",
    "start": "node dist/index.js",
    "dev": "ts-node index.ts",
    "dev:watch": "nodemon --exec ts-node index.ts",
    "db:push": "prisma db push",
    "pm2": "pm2 start index.ts --name kuroneko --interpreter node --node-args=\"-r ts-node/register\" && pm2 save"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "axios-cookiejar-support": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "file-type": "^16.5.4",
    "form-data": "^4.0.0",
    "jimp": "^0.22.10",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^3.3.7",
    "resend": "^4.0.1",
    "@prisma/client": "^6.19.3",
    "stripe": "^17.4.0",
    "tough-cookie": "^4.1.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.1",
    "@types/express": "^4.17.21",
    "@types/form-data": "^2.5.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.10.0",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  }
}
